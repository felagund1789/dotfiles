{
    "layer": "top",
    "position": "top",
    "reload_style_on_change": true,
    "modules-left": ["hyprland/workspaces", "custom/updates", "mpris"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["tray", "hyprland/language", "pulseaudio#microphone", "pulseaudio#speaker", "network", "bluetooth", "battery", "clock", "custom/notification"],

    "hyprland/workspaces": {
        "on-scroll-up": "hyprctl dispatch workspace r-1",
        "on-scroll-down": "hyprctl dispatch workspace r+1",
        "format": "{icon}",
        "format-icons": {
            "active": "οÜ£",
            "default": "ο³ë",
            "empty": "ο³¨"
        },
        "persistent-workspaces": {
            "*": [1, 2, 3, 4, 5, 6, 7, 8]
        }
    },
    "custom/updates": {
        "format": "σΑöΑ  {}",
        "interval": 3600,
        "exec": "paru -Qu 2>/dev/null | wc -l",
        "exec-if": "paru -Qu 2>/dev/null | grep -q .",
        "on-click": "kitty -e paru -Syu",
        "tooltip": false
    },
    "mpris": {
        "player": "playerctld",
        "format": "{player_icon}  {status_icon} {dynamic}",
        "format-playing": "{player_icon}  {status_icon} {dynamic}",
        "format-paused": "{player_icon}  {status_icon} {dynamic}",
        "format-stopped": "",
        "dynamic-order": ["artist", "title"],
        "dynamic-separator": " βÄî ",
        "dynamic-len": 75,
        "tooltip-format": "{artist} βÄî {title}\n{position}/{length}",
        "player-icons": {
            "default": "σΑéà",
            "spotify": "οÜΦ",
            "firefox": "οâ©",
            "mpv": "σΑÉΫ"
        },
        "status-icons": {
            "playing": "ο¹¨",
            "paused": "ο¹΄",
            "stopped": ""
        },
        "on-click": "playerctl play-pause",
        "on-click-middle": "playerctl previous",
        "on-click-right": "playerctl next"
    },
    "custom/notification": {
        "return-type": "json",
        "interval": 3,
        "exec": "bash ~/.config/waybar/scripts/notification.sh",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d",
        "escape": true,
        "tooltip": true
    },
    "tray": {
        "icon-size": 14,
        "spacing": 10
    },
    "clock": {
        "interval": 1,
        "format": "σΑΞî  {:%H:%M}",
        "format-alt": "ο¹≥  {:%a, %d %b %Y}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "weeks-pos": "right",
            "on-scroll": 1
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "network": {
        "interval": 3,
        "format-wifi": "{icon}  {essid} ({signalStrength}%)",
        "format-ethernet": "σΑàÄ",
        "format-linked": "σ±‰•",
        "format-disconnected": "σΑ•Σ",
        "format-disabled": "σΑ•Σ",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "{ifname} {ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "format-icons": ["σΑΛ·", "σΑΛü", "σΑΛΔ", "σΑΛΞ", "σΑΛ®"]
    },
    "bluetooth": {
        "format-on": "σΑ²·",
        "format-off": "σΑ²≤",
        "format-disabled": "σΑ²≤",
        "format-connected": "σΑ²± {device_alias}",
        "tooltip-format": "Bluetooth on",
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click": "bash ~/.config/waybar/scripts/bluetooth_menu.sh",
        "on-click-right": "blueman-manager"
    },
    "hyprland/language": {
        "format": "{}",
        "format-en": "EN",
        "format-gr": "GR",
        "tooltip": true,
        "on-click": "hyprctl switchxkblayout all next"
    },
    "battery": {
        "interval": 10,
        "states": {
            "good": 90,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "σΑ²³ {capacity}%",
        "format-plugged": "σΑ²³ {capacity}%",
        "tooltip-format": "{timeTo}",
        "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"]
    },
    "pulseaudio#speaker": {
        "scroll-step": 2,
        "on-click": "bash ~/.config/waybar/scripts/audio_menu.sh",
        "on-click-middle": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "format": "{icon} {volume}%",
        "format-muted": "σΑùü",
        "tooltip-format": "{desc} {volume}%",
        "format-icons": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
    },
    "pulseaudio#microphone": {
        "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
        "on-click-right": "pavucontrol",
        "format": "{format_source}",
        "format-source": "ο³Α",
        "format-source-muted": "ο³±",
        "tooltip-format": "Microphone {format_source}"
    }
}
