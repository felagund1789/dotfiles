{
    "layer": "top",
    "position": "top",
    "spacing": 8,
    "reload_style_on_change": true,
    "modules-left": ["hyprland/workspaces", "mpris"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["pulseaudio#microphone", "pulseaudio#speaker", "network", "bluetooth", "hyprland/language", "battery", "tray", "clock", "custom/notification"],

    "hyprland/workspaces": {
        "on-scroll-up": "hyprctl dispatch workspace r-1",
        "on-scroll-down": "hyprctl dispatch workspace r+1",
        "format": "{icon}",
        "format-icons": {
            "active": "ï†’",
            "default": "ï„‘",
            "empty": "ï„Œ"
        },
        "persistent-workspaces": {
            "*": [1, 2, 3, 4, 5]
        }
    },
    "mpris": {
        "player": "playerctld",
        "format": "{player_icon} {dynamic}",
        "format-playing": "{player_icon} {dynamic}",
        "format-paused": "{player_icon} {dynamic}",
        "format-stopped": "",
        "dynamic-order": ["title", "artist", "position", "length"],
        "dynamic-separator": " â€” ",
        "dynamic-len": 58,
        "tooltip-format": "{player}: {title} â€” {artist}\n{position}/{length}",
        "player-icons": {
            "default": "َ°ژˆ",
            "spotify": "ï†¼",
            "firefox": "ï‰©",
            "mpv": "َ°ƒ½"
        },
        "status-icons": {
            "playing": "ïپŒ",
            "paused": "ïپ‹",
            "stopped": ""
        },
        "on-click": "playerctl play-pause",
        "on-click-middle": "playerctl previous",
        "on-click-right": "playerctl next"
    },
    "custom/notification": {
        "return-type": "json",
        "interval": 3,
        "exec": "~/.config/waybar/scripts/notification.sh",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d",
        "escape": true,
        "tooltip": true
    },
    "tray": {
        "icon-size": 14,
        "spacing": 10
    },
    "clock": {
        "interval": 1,
        "format": "َ°¥” {:%H:%M}",
        "format-alt": "ïپ³ {:%a, %d %b %Y}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "weeks-pos": "right",
            "on-scroll": 1
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "network": {
        "interval": 3,
        "format-wifi": "{icon} {signalStrength}%",
        "format-ethernet": "َ°ˆ€",
        "format-linked": "َ±ک–",
        "format-disconnected": "َ°–ھ",
        "format-disabled": "َ°–ھ",
        "on-click": "bash ~/.config/waybar/scripts/wifi_menu.sh",
        "on-click-right": "kitty -e nmtui",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "{ifname} {ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"]
    },
    "bluetooth": {
        "format-on": "َ°‚¯",
        "format-off": "َ°‚²",
        "format-disabled": "َ°‚²",
        "format-connected": "َ°‚± {device_alias}",
        "tooltip-format": "Bluetooth on",
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click": "bash ~/.config/waybar/scripts/bluetooth_menu.sh",
        "on-click-right": "kitty -e bluetui"
    },
    "hyprland/language": {
        "format": "{}",
        "format-en": "EN",
        "format-gr": "GR",
        "tooltip": true,
        "on-click": "hyprctl switchxkblayout all next"
    },
    "battery": {
        "interval": 10,
        "states": {
            "good": 90,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°‚„ {capacity}%",
        "tooltip-format": "{timeTo}",
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
    },
    "pulseaudio#speaker": {
        "scroll-step": 2,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں",
        "tooltip-format": "{desc} {volume}%",
        "format-icons": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "pulseaudio#microphone": {
        "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
        "on-click-right": "pavucontrol",
        "format": "{format_source}",
        "format-source": "ï„°",
        "format-source-muted": "ï„±",
        "tooltip-format": "Microphone {format_source}"
    }
}
